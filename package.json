{
  "name": "@nabla/root",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "bun test",
    "license:check": "license-checker-rseidelsohn --production --onlyAllow \"$(cat .licenses/allowed.json | jq -r '.licenses | join(\";\")')\" --excludePrivatePackages",
    "license:audit": "bun run scripts/license-audit.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@nabla/shared": "workspace:*",
    "@types/bun": "1.3.13",
    "@types/node": "25.6.0",
    "license-checker-rseidelsohn": "4.4.2",
    "lefthook": "1.13.6",
    "typescript": "6.0.3"
  }
}
